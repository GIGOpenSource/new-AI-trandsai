{
  "pages": [
    {
      "path": "pages/login/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "登录"
      }
    },
    {
      "path": "pages/register/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "注册"
      }
    },
    {
      "path": "pages/home/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "首页"
      }
    },
    {
      "path": "pages/messages/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "消息"
      }
    },
    {
      "path": "pages/discover/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "发现"
      }
    },
    {
      "path": "pages/profile/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "我的"
      }
    },
    {
      "path": "pages/chat/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "聊天",
        "disableScroll": true
      }
    }
  ],
  "subPackages": [
    {
      "root": "pages-sub",
      "pages": [
        { "path": "companion/index", "style": { "navigationStyle": "custom", "navigationBarTitleText": "资料" } },
        { "path": "create/index", "style": { "navigationStyle": "custom", "navigationBarTitleText": "创建" } },
        { "path": "feedback/index", "style": { "navigationStyle": "custom", "navigationBarTitleText": "反馈" } },
        { "path": "my-companions/index", "style": { "navigationStyle": "custom", "navigationBarTitleText": "我的伴侣" } },
        { "path": "intimacy/index", "style": { "navigationStyle": "custom", "navigationBarTitleText": "亲密度" } },
        { "path": "my-posts/index", "style": { "navigationStyle": "custom", "navigationBarTitleText": "我的帖子" } },
        { "path": "notifications/index", "style": { "navigationStyle": "custom", "navigationBarTitleText": "通知" } },
        { "path": "settings/index", "style": { "navigationStyle": "custom", "navigationBarTitleText": "通知设置" } },
        { "path": "privacy/index", "style": { "navigationStyle": "custom", "navigationBarTitleText": "隐私政策" } },
        { "path": "moment/index", "style": { "navigationStyle": "custom", "navigationBarTitleText": "朋友圈详情" } },
        { "path": "post/index", "style": { "navigationStyle": "custom", "navigationBarTitleText": "帖子详情" } },
        { "path": "not-found/index", "style": { "navigationStyle": "custom", "navigationBarTitleText": "404" } }
      ]
    }
  ],
  "preloadRule": {
    "pages/home/index": { "network": "all", "packages": ["pages-sub"] }
  },
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarBackgroundColor": "#0f0f12",
    "backgroundColor": "#0f0f12",
    "backgroundColorTop": "#0f0f12",
    "backgroundColorBottom": "#0f0f12"
  },
  "easycom": {
    "autoscan": true,
    "custom": {
      "^App(.*)": "@/components/App$1.vue"
    }
  }
}
